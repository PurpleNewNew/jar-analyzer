<?xml version="1.0" encoding="UTF-8"?>
<web-app>
    <listener>
        <listener-class>com.example.ssm.bootstrap.AppBootstrapListener</listener-class>
    </listener>
    <filter>
        <filter-name>authFilter</filter-name>
        <filter-class>com.example.ssm.web.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>authFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <servlet>
        <servlet-name>dispatchServlet</servlet-name>
        <servlet-class>com.example.ssm.web.DispatchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>dispatchServlet</servlet-name>
        <url-pattern>/legacy/*</url-pattern>
    </servlet-mapping>
</web-app>
